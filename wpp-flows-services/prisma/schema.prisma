// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id
  name          String
  email         String
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  accounts      Account[]
  organization  Organization?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  ownerId   String   @unique
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Mercado Pago access token (Brazilian PaaS test/prod). Per-org so each
  /// restaurant collects into its own MP account.
  mercadoPagoAccessToken String?
  mercadoPagoPublicKey   String?
  /// Webhook validation secret (used by /webhook/mercadopago to confirm origin).
  mercadoPagoWebhookSecret String?
  /// PIX key (cpf/cnpj/email/phone/random) where the wallet pays out withdrawals.
  payoutPixKey           String?
  payoutPixKeyType       String?
  /// Per-org notification toggles (new orders, bot disconnects, idle convs).
  notificationPreferences Json?
  /// Minutes before an unpaid order auto-cancels (default 15). Replaces the
  /// per-step PAYMENT metadata since payment lives on the web checkout now.
  paymentTimeoutMinutes  Int     @default(15)
  /// Message sent on WhatsApp when the customer cancels their pending order
  /// from the web checkout. Null = fall back to a friendly default.
  paymentCancelMessage   String?
  /// Message sent on WhatsApp when the order auto-cancels after the timeout
  /// window. Null = fall back to a friendly default.
  paymentTimeoutMessage  String?
  /// Message sent on WhatsApp when the customer hits the post-checkout
  /// success page and taps the deep-link (matched by "Pedido #XXXX confirmado").
  /// Null = fall back to a friendly default.
  paymentReceivedMessage String?
  /// Flat delivery fee added to web-checkout orders when the customer chooses
  /// delivery (vs. pickup). 0 = free delivery. Stored as Decimal for currency safety.
  deliveryFee            Decimal @default(0) @db.Decimal(10, 2)
  /// Operating hours shared across the restaurant. The WhatsApp flow runner and
  /// public menu site both honor these — having them at the org level means a
  /// multi-bot setup doesn't disagree about whether the restaurant is open.
  /// 0..6 (Sunday..Saturday). Empty = open every day. Null start/end = no
  /// time-of-day restriction.
  workingDaysOfWeek      Int[]     @default([])
  workingStartTime       String?
  workingEndTime         String?
  /// Sent on WhatsApp when an inbound message arrives outside working hours.
  /// Accepts {{days_of_work}}, {{from}}, {{to}} variables.
  outOfHoursMessage      String?
  /// Cooldown (minutes) between consecutive bot replies on the same conversation.
  /// While the cooldown is active, inbound customer messages are accepted (logged
  /// + visible in the dashboard) but the flow runner doesn't reply — operators
  /// can step in via the dashboard. 0 = no cooldown.
  botCooldownMinutes     Int     @default(60)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bots          Bot[]
  categories    MenuCategory[]
  items         MenuItem[]
  flows         Flow[]
  conversations Conversation[]
  customers     Customer[]
  orders        Order[]
  wallet        Wallet?
  promotions    Promotion[]
  notifications Notification[]
  coupons       Coupon[]

  @@map("organization")
}

enum BotStatus {
  CONNECTING
  ONLINE
  OFFLINE
  ERROR
}

model Bot {
  id                   String    @id @default(uuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                 String
  evolutionInstanceName String   @unique
  phoneNumber          String?
  status               BotStatus @default(CONNECTING)
  qrCode               String?
  webhookUrl           String?
  flowId               String?
  flow                 Flow?     @relation(fields: [flowId], references: [id], onDelete: SetNull)
  lastConnectedAt      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  conversations Conversation[]

  @@index([organizationId])
  @@map("bot")
}

model MenuCategory {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items MenuItem[]

  @@index([organizationId])
  @@map("menu_category")
}

model MenuItem {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoryId     String
  category       MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name           String
  description    String
  price          Decimal  @db.Decimal(10, 2)
  imageUrl       String?
  available      Boolean  @default(true)
  /// 0–6 (Sunday..Saturday). Empty array means available every day. When set,
  /// the bot only lists this item on the matching weekdays.
  availableDaysOfWeek Int[] @default([])
  position       Int      @default(0)
  /// Optional adicionais the customer can tick when ordering this item on the
  /// public menu (e.g. "Borda recheada", "Queijo extra"). Shape:
  ///   [{ id: string, name: string, price: string }]
  /// Stored as JSON because the list is small and item-scoped — querying
  /// inside it isn't needed.
  additionals    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  featuredInPromotions Promotion[]

  @@index([organizationId])
  @@index([categoryId])
  @@map("menu_item")
}

model Flow {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isActive       Boolean  @default(false)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps FlowStep[]
  bots  Bot[]

  @@unique([organizationId, name, version])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("flow")
}

enum FlowStepType {
  MESSAGE
}

model FlowStep {
  id        String       @id @default(uuid())
  flowId    String
  flow      Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  type      FlowStepType
  content   String
  order     Int          @default(0)
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([flowId])
  @@map("flow_step")
}

enum ConversationStatus {
  OPEN
  CLOSED
  PENDING
}

model Conversation {
  id              String   @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  botId           String
  bot             Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  remoteJid       String
  contactName     String
  contactPhone    String
  contactAvatar   String?
  status          ConversationStatus @default(OPEN)
  unreadCount     Int      @default(0)
  lastMessagePreview String  @default("")
  lastMessageAt   DateTime @default(now())
  botActive       Boolean  @default(true)
  currentStepId   String?
  flowState       Json?
  /// Timestamp of the bot's most recent outbound message on this conversation.
  /// Combined with `Organization.botCooldownMinutes`, the flow runner skips
  /// re-firing the flow while the customer is in active back-and-forth so
  /// operators can take over without the bot spamming over them.
  lastBotReplyAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages Message[]
  orders   Order[]

  @@unique([botId, remoteJid])
  @@index([organizationId])
  @@index([botId])
  @@index([customerId])
  @@map("conversation")
}

model Customer {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  orderCount     Int          @default(0)
  /// Snapshot of recent addresses the customer has used. Newest first.
  savedAddresses Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversations Conversation[]
  orders        Order[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("customer")
}

enum OrderStatus {
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryMode {
  PICKUP
  DELIVERY
}

model Order {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  /// Auto-incrementing display number scoped to the organization. Populated by the use case.
  sequence        Int
  /// Snapshot of items at the time of order, shape matches FlowCartItem.
  items           Json
  subtotal        Decimal       @db.Decimal(10, 2)
  discount        Decimal?      @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  status          OrderStatus   @default(RECEIVED)
  observation     String?
  address         String?
  /// PICKUP = customer picks the order up at the restaurant; DELIVERY = restaurant delivers
  /// and `deliveryFee` (snapshot of the org's fee at order time) is added to the total.
  deliveryMode    DeliveryMode  @default(DELIVERY)
  deliveryFee     Decimal       @default(0) @db.Decimal(10, 2)
  /// Code of the coupon applied at checkout (if any). The discount it produced
  /// is rolled into `discount` along with any other applied promotions.
  couponCode      String?
  couponDiscount  Decimal?      @db.Decimal(10, 2)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentProvider String?
  paymentProviderRef String?
  paymentLink     String?
  receiptUrl      String?
  /// Snapshot of the applied promotion ids (if any) so we can audit later.
  appliedPromotionIds Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  walletTransactions WalletTransaction[]

  @@unique([organizationId, sequence])
  @@index([organizationId])
  @@index([customerId])
  @@index([conversationId])
  @@index([organizationId, status])
  @@map("order")
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id             String              @id @default(uuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Case-insensitive code the customer types at checkout. We normalize to
  /// uppercase before saving and compare case-insensitively at validation.
  code           String
  discountType   CouponDiscountType
  /// For PERCENT: 0-100. For FIXED: BRL amount.
  discountValue  Decimal             @db.Decimal(10, 2)
  isActive       Boolean             @default(true)
  /// Inclusive validity window. Both null = always valid.
  validFrom      DateTime?
  validUntil     DateTime?
  /// Free-text label shown to the org owner (optional).
  description    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("coupon")
}

model Wallet {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  balance        Decimal      @default(0) @db.Decimal(10, 2)
  currency       String       @default("BRL")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  transactions WalletTransaction[]

  @@map("wallet")
}

enum WalletTxKind {
  CREDIT
  WITHDRAWAL
}

enum WalletTxStatus {
  PENDING
  COMPLETED
  REJECTED
}

model WalletTransaction {
  id        String         @id @default(uuid())
  walletId  String
  wallet    Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  kind      WalletTxKind
  amount    Decimal        @db.Decimal(10, 2)
  status    WalletTxStatus @default(COMPLETED)
  orderId   String?
  order     Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([walletId])
  @@index([walletId, status])
  @@map("wallet_transaction")
}

enum PromotionKind {
  /// Discount applied when the customer hits the configured order number
  /// (e.g. every 5th order: 10% off).
  NTH_ORDER_DISCOUNT
  /// Free-text "promotion of the day" message inserted before the menu.
  DAILY_MESSAGE
  /// Orderable combo. Carries its full configuration in the `bundle` JSON
  /// column (components/pools, fixed price, per-bundle questions). Shows up
  /// as a virtual "Promoções" category in the menu and is picked by the
  /// customer like any other item.
  BUNDLE
}

enum PromotionDiscountType {
  PERCENT
  FIXED
}

model Promotion {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kind           PromotionKind
  name           String
  isActive       Boolean       @default(true)
  /// NTH_ORDER_DISCOUNT: every Nth order qualifies.
  nthOrder       Int?
  /// NTH_ORDER_DISCOUNT: discount amount (% or fixed BRL).
  discountType   PromotionDiscountType?
  discountValue  Decimal?      @db.Decimal(10, 2)
  /// DAILY_MESSAGE: 0–6 (sunday..saturday) days the message fires. Empty = every day.
  daysOfWeek     Int[]         @default([])
  /// Message sent before showing the menu (DAILY_MESSAGE only).
  message        String?
  /// DAILY_MESSAGE: optional menu item highlighted as the "item do dia". The
  /// flow runner appends item details to the greeting message and, when
  /// `promotionalPrice` is set, discounts the price difference at checkout.
  featuredItemId    String?
  featuredItem      MenuItem? @relation(fields: [featuredItemId], references: [id], onDelete: SetNull)
  promotionalPrice  Decimal?  @db.Decimal(10, 2)
  /// NTH_ORDER_DISCOUNT: optional teaser shown the order *before* the qualifying one
  /// (e.g. shown on the 3rd order announcing the 5th-order bonus).
  teaserOrderOffset Int?
  teaserMessage     String?
  /// NTH_ORDER_DISCOUNT: customer-facing banner on the public checkout when
  /// the customer hits the qualifying order ("🎉 5º pedido — 10% off aplicado!").
  /// Null = auto-built default.
  qualifyingMessage String?
  /// BUNDLE: full combo configuration. Shape:
  ///   { components: [{ id, label, itemIds, count, free }],
  ///     price: "59.90",
  ///     questions: [{ id, label, fieldKey }] }
  /// Stored as JSON because the shape will evolve as we ship the orderable
  /// promo experience and we don't query inside it.
  bundle         Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([featuredItemId])
  @@map("promotion")
}

enum MessageAuthor {
  BOT
  USER
  AGENT
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  evolutionMessageId String?  @unique
  author          MessageAuthor
  content         String
  status          MessageStatus @default(SENT)
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@map("message")
}

enum NotificationType {
  NEW_ORDER
  PAYMENT_RECEIVED
  BOT_OFFLINE
  IDLE_CONVERSATION
  GENERIC
}

model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           NotificationType
  title          String
  body           String?
  /// Optional deep-link inside the dashboard (e.g. "/orders/<id>").
  link           String?
  /// When the notification was marked as read. Read notifications are deleted
  /// 24h after this timestamp by a lazy cleanup that runs on every list query.
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, readAt])
  @@map("notification")
}
