// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id
  name            String
  email           String
  emailVerified   Boolean       @default(false)
  image           String?
  isAdmin         Boolean       @default(false)
  createdAt       DateTime      @default(now()) @db.Timestamptz
  updatedAt       DateTime      @updatedAt @db.Timestamptz
  sessions        Session[]
  accounts        Account[]
  organization    Organization?
  sentInvitations Invitation[]  @relation("InvitedBy")

  @@unique([email])
  @@map("user")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invitation {
  id          String           @id @default(uuid())
  email       String
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime         @db.Timestamptz
  acceptedAt  DateTime?        @db.Timestamptz
  invitedById String
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now()) @db.Timestamptz
  updatedAt   DateTime         @updatedAt @db.Timestamptz

  @@index([email])
  @@index([invitedById])
  @@map("invitation")
}

model Session {
  id        String   @id
  expiresAt DateTime @db.Timestamptz
  token     String
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz
  refreshTokenExpiresAt DateTime? @db.Timestamptz
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @updatedAt @db.Timestamptz

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id                       String   @id @default(uuid())
  name                     String
  slug                     String   @unique
  ownerId                  String   @unique
  owner                    User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Mercado Pago access token (Brazilian PaaS test/prod). Per-org so each
  /// restaurant collects into its own MP account.
  mercadoPagoAccessToken   String?
  mercadoPagoPublicKey     String?
  /// Webhook validation secret (used by /webhook/mercadopago to confirm origin).
  mercadoPagoWebhookSecret String?
  /// PIX key (cpf/cnpj/email/phone/random) where the wallet pays out withdrawals.
  payoutPixKey             String?
  payoutPixKeyType         String?
  /// Per-org notification toggles (new orders, bot disconnects, idle convs).
  notificationPreferences  Json?
  /// Minutes before an unpaid order auto-cancels (default 15). Replaces the
  /// per-step PAYMENT metadata since payment lives on the web checkout now.
  paymentTimeoutMinutes    Int      @default(15)
  /// Message sent on WhatsApp when the customer cancels their pending order
  /// from the web checkout. Null = fall back to a friendly default.
  paymentCancelMessage     String?
  /// Message sent on WhatsApp when the order auto-cancels after the timeout
  /// window. Null = fall back to a friendly default.
  paymentTimeoutMessage    String?
  /// Message sent on WhatsApp when the customer hits the post-checkout
  /// success page and taps the deep-link (matched by "Pedido #XXXX confirmado").
  /// Null = fall back to a friendly default.
  paymentReceivedMessage   String?
  /// Flat delivery fee added to web-checkout orders when the customer chooses
  /// delivery (vs. pickup). 0 = free delivery. Stored as Decimal for currency safety.
  deliveryFee              Decimal  @default(0) @db.Decimal(10, 2)
  /// Operating hours shared across the restaurant. The WhatsApp flow runner and
  /// public menu site both honor these — having them at the org level means a
  /// multi-bot setup doesn't disagree about whether the restaurant is open.
  /// 0..6 (Sunday..Saturday). Empty = open every day. Null start/end = no
  /// time-of-day restriction.
  workingDaysOfWeek        Int[]    @default([])
  workingStartTime         String?
  workingEndTime           String?
  /// Sent on WhatsApp when an inbound message arrives outside working hours.
  /// Accepts {{days_of_work}}, {{from}}, {{to}} variables.
  outOfHoursMessage        String?
  localWorkingDaysOfWeek   Int[]    @default([])
  localWorkingStartTime    String?
  localWorkingEndTime      String?
  localOutOfHoursMessage   String?
  /// Cooldown (minutes) between consecutive bot replies on the same conversation.
  /// While the cooldown is active, inbound customer messages are accepted (logged
  /// + visible in the dashboard) but the flow runner doesn't reply — operators
  /// can step in via the dashboard. 0 = no cooldown.
  botCooldownMinutes       Int      @default(60)
  createdAt                DateTime @default(now()) @db.Timestamptz
  updatedAt                DateTime @updatedAt @db.Timestamptz

  bots          Bot[]
  categories    MenuCategory[]
  items         MenuItem[]
  flows         Flow[]
  conversations Conversation[]
  customers     Customer[]
  orders        Order[]
  wallet        Wallet?
  promotions    Promotion[]
  notifications Notification[]
  coupons       Coupon[]
  tables        RestaurantTable[]
  reports       Report[]

  @@map("organization")
}

enum BotStatus {
  CONNECTING
  ONLINE
  OFFLINE
  ERROR
}

enum BotDesiredState {
  CONNECTED
  DISCONNECTED
}

model Bot {
  id                       String          @id @default(uuid())
  organizationId           String
  organization             Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                     String
  evolutionInstanceName    String          @unique
  phoneNumber              String?
  status                   BotStatus       @default(CONNECTING)
  desiredState             BotDesiredState @default(CONNECTED)
  qrCode                   String?
  webhookUrl               String?
  flowId                   String?
  flow                     Flow?           @relation(fields: [flowId], references: [id], onDelete: SetNull)
  lastConnectedAt          DateTime?       @db.Timestamptz
  recoveryAttempts         Int             @default(0)
  lastRecoveryAt           DateTime?       @db.Timestamptz
  lastDisconnectNotifiedAt DateTime?       @db.Timestamptz
  createdAt                DateTime        @default(now()) @db.Timestamptz
  updatedAt                DateTime        @updatedAt @db.Timestamptz

  conversations Conversation[]

  @@index([organizationId])
  @@map("bot")
}

model MenuCategory {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceType    ServiceType  @default(DELIVERY)
  name           String
  description    String?
  position       Int          @default(0)
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  items MenuItem[]

  @@index([organizationId])
  @@index([organizationId, serviceType])
  @@map("menu_category")
}

model MenuItem {
  id                  String       @id @default(uuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoryId          String
  category            MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  serviceType         ServiceType  @default(DELIVERY)
  name                String
  description         String
  price               Decimal      @db.Decimal(10, 2)
  /// Optional discounted price. When set, this is what the customer pays and
  /// `price` is shown struck-through in the catalog.
  promotionalPrice    Decimal?     @db.Decimal(10, 2)
  imageUrl            String?
  available           Boolean      @default(true)
  /// 0–6 (Sunday..Saturday). Empty array means available every day. When set,
  /// the bot only lists this item on the matching weekdays.
  availableDaysOfWeek Int[]        @default([])
  position            Int          @default(0)
  /// Shape:
  ///   [{
  ///     id: string, title: string, subtitle?: string|null,
  ///     minSelections: number, maxSelections: number, position: number,
  ///     options: [{ id: string, name: string, additionalPrice: string,
  ///                 imageUrl?: string|null, position: number }]
  ///   }]
  /// JSON because every read fetches the whole list together and the
  /// browse / order paths don't need to query inside it.
  optionGroups        Json?
  createdAt           DateTime     @default(now()) @db.Timestamptz
  updatedAt           DateTime     @updatedAt @db.Timestamptz

  featuredInPromotions Promotion[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([organizationId, serviceType])
  @@map("menu_item")
}

model Flow {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isActive       Boolean      @default(false)
  version        Int          @default(1)
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  steps FlowStep[]
  bots  Bot[]

  @@unique([organizationId, name, version])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("flow")
}

enum FlowStepType {
  MESSAGE
}

model FlowStep {
  id        String       @id @default(uuid())
  flowId    String
  flow      Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  type      FlowStepType
  content   String
  order     Int          @default(0)
  metadata  Json?
  createdAt DateTime     @default(now()) @db.Timestamptz
  updatedAt DateTime     @updatedAt @db.Timestamptz

  @@index([flowId])
  @@map("flow_step")
}

enum ConversationStatus {
  OPEN
  CLOSED
  PENDING
}

model Conversation {
  id                 String             @id @default(uuid())
  organizationId     String
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  botId              String
  bot                Bot                @relation(fields: [botId], references: [id], onDelete: Cascade)
  customerId         String?
  customer           Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  remoteJid          String
  contactName        String
  contactPhone       String
  contactAvatar      String?
  status             ConversationStatus @default(OPEN)
  unreadCount        Int                @default(0)
  lastMessagePreview String             @default("")
  lastMessageAt      DateTime           @default(now()) @db.Timestamptz
  botActive          Boolean            @default(true)
  currentStepId      String?
  flowState          Json?
  /// Timestamp of the bot's most recent outbound message on this conversation.
  /// Combined with `Organization.botCooldownMinutes`, the flow runner skips
  /// re-firing the flow while the customer is in active back-and-forth so
  /// operators can take over without the bot spamming over them.
  lastBotReplyAt     DateTime?          @db.Timestamptz
  createdAt          DateTime           @default(now()) @db.Timestamptz
  updatedAt          DateTime           @updatedAt @db.Timestamptz

  messages Message[]
  orders   Order[]

  @@unique([botId, remoteJid])
  @@index([organizationId])
  @@index([botId])
  @@index([customerId])
  @@map("conversation")
}

model Customer {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String
  orderCount     Int          @default(0)
  /// Snapshot of recent addresses the customer has used. Newest first.
  savedAddresses Json?
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  conversations Conversation[]
  orders        Order[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("customer")
}

enum OrderStatus {
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryMode {
  PICKUP
  DELIVERY
}

enum ServiceType {
  DELIVERY
  LOCAL
}

enum TableStatus {
  EMPTY
  OCCUPIED
  BILL_REQUESTED
}

model RestaurantTable {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label           String
  qrToken         String       @unique
  position        Int          @default(0)
  seats           Int?
  notes           String?
  status          TableStatus  @default(EMPTY)
  billRequestedAt DateTime?    @db.Timestamptz
  createdAt       DateTime     @default(now()) @db.Timestamptz
  updatedAt       DateTime     @updatedAt @db.Timestamptz

  orders Order[]
  bills  TableBill[]

  @@unique([organizationId, label])
  @@index([organizationId])
  @@map("restaurant_table")
}

model TableBill {
  id             String           @id @default(uuid())
  organizationId String
  tableId        String?
  table          RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableLabel     String?
  total          Decimal          @db.Decimal(10, 2)
  paymentMethod  String
  notes          String?
  closedAt       DateTime         @default(now()) @db.Timestamptz
  closedById     String
  createdAt      DateTime         @default(now()) @db.Timestamptz

  orders Order[]

  @@index([organizationId])
  @@index([tableId])
  @@index([organizationId, closedAt])
  @@map("table_bill")
}

model Order {
  id                  String           @id @default(uuid())
  organizationId      String
  organization        Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId          String
  customer            Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversationId      String?
  conversation        Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  /// Auto-incrementing display number scoped to the organization. Populated by the use case.
  sequence            Int
  /// Snapshot of items at the time of order, shape matches FlowCartItem.
  items               Json
  subtotal            Decimal          @db.Decimal(10, 2)
  discount            Decimal?         @db.Decimal(10, 2)
  total               Decimal          @db.Decimal(10, 2)
  status              OrderStatus      @default(RECEIVED)
  observation         String?
  address             String?
  /// PICKUP = customer picks the order up at the restaurant; DELIVERY = restaurant delivers
  /// and `deliveryFee` (snapshot of the org's fee at order time) is added to the total.
  deliveryMode        DeliveryMode     @default(DELIVERY)
  deliveryFee         Decimal          @default(0) @db.Decimal(10, 2)
  /// Code of the coupon applied at checkout (if any). The discount it produced
  /// is rolled into `discount` along with any other applied promotions.
  couponCode          String?
  couponDiscount      Decimal?         @db.Decimal(10, 2)
  paymentStatus       PaymentStatus    @default(PENDING)
  paymentProvider     String?
  paymentProviderRef  String?
  paymentLink         String?
  receiptUrl          String?
  cashChangeFor       Decimal?         @db.Decimal(10, 2)
  /// Snapshot of the applied promotion ids (if any) so we can audit later.
  appliedPromotionIds Json?
  serviceType         ServiceType      @default(DELIVERY)
  tableId             String?
  table               RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableLabel          String?
  billId              String?
  bill                TableBill?       @relation(fields: [billId], references: [id], onDelete: SetNull)
  createdAt           DateTime         @default(now()) @db.Timestamptz
  updatedAt           DateTime         @updatedAt @db.Timestamptz

  walletTransactions WalletTransaction[]

  @@unique([organizationId, sequence])
  @@index([organizationId])
  @@index([customerId])
  @@index([conversationId])
  @@index([organizationId, status])
  @@index([organizationId, serviceType])
  @@index([tableId])
  @@index([billId])
  @@map("order")
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id             String             @id @default(uuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Case-insensitive code the customer types at checkout. We normalize to
  /// uppercase before saving and compare case-insensitively at validation.
  code           String
  discountType   CouponDiscountType
  /// For PERCENT: 0-100. For FIXED: BRL amount.
  discountValue  Decimal            @db.Decimal(10, 2)
  isActive       Boolean            @default(true)
  /// Inclusive validity window. Both null = always valid.
  validFrom      DateTime?          @db.Timestamptz
  validUntil     DateTime?          @db.Timestamptz
  /// Free-text label shown to the org owner (optional).
  description    String?
  createdAt      DateTime           @default(now()) @db.Timestamptz
  updatedAt      DateTime           @updatedAt @db.Timestamptz

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("coupon")
}

model Wallet {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  balance        Decimal      @default(0) @db.Decimal(10, 2)
  localBalance   Decimal      @default(0) @db.Decimal(10, 2)
  currency       String       @default("BRL")
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  transactions WalletTransaction[]

  @@map("wallet")
}

enum WalletTxKind {
  CREDIT
  WITHDRAWAL
}

enum WalletTxStatus {
  PENDING
  COMPLETED
  REJECTED
}

model WalletTransaction {
  id          String         @id @default(uuid())
  walletId    String
  wallet      Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  kind        WalletTxKind
  amount      Decimal        @db.Decimal(10, 2)
  status      WalletTxStatus @default(COMPLETED)
  orderId     String?
  order       Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  billId      String?
  note        String?
  serviceType ServiceType    @default(DELIVERY)
  createdAt   DateTime       @default(now()) @db.Timestamptz
  updatedAt   DateTime       @updatedAt @db.Timestamptz

  @@index([walletId])
  @@index([walletId, status])
  @@index([walletId, serviceType])
  @@index([billId])
  @@map("wallet_transaction")
}

enum PromotionKind {
  /// Discount applied when the customer hits the configured order number
  /// (e.g. every 5th order: 10% off).
  NTH_ORDER_DISCOUNT
  /// Free-text "promotion of the day" message inserted before the menu.
  DAILY_MESSAGE
}

enum PromotionDiscountType {
  PERCENT
  FIXED
}

model Promotion {
  id                String                 @id @default(uuid())
  organizationId    String
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kind              PromotionKind
  name              String
  isActive          Boolean                @default(true)
  /// NTH_ORDER_DISCOUNT: every Nth order qualifies.
  nthOrder          Int?
  /// NTH_ORDER_DISCOUNT: discount amount (% or fixed BRL).
  discountType      PromotionDiscountType?
  discountValue     Decimal?               @db.Decimal(10, 2)
  /// DAILY_MESSAGE: 0–6 (sunday..saturday) days the message fires. Empty = every day.
  daysOfWeek        Int[]                  @default([])
  /// Message sent before showing the menu (DAILY_MESSAGE only).
  message           String?
  /// DAILY_MESSAGE: optional menu item highlighted as the "item do dia". The
  /// flow runner appends item details to the greeting message and, when
  /// `promotionalPrice` is set, discounts the price difference at checkout.
  featuredItemId    String?
  featuredItem      MenuItem?              @relation(fields: [featuredItemId], references: [id], onDelete: SetNull)
  promotionalPrice  Decimal?               @db.Decimal(10, 2)
  /// NTH_ORDER_DISCOUNT: optional teaser shown the order *before* the qualifying one
  /// (e.g. shown on the 3rd order announcing the 5th-order bonus).
  teaserOrderOffset Int?
  teaserMessage     String?
  /// NTH_ORDER_DISCOUNT: customer-facing banner on the public checkout when
  /// the customer hits the qualifying order ("🎉 5º pedido — 10% off aplicado!").
  /// Null = auto-built default.
  qualifyingMessage String?
  createdAt         DateTime               @default(now()) @db.Timestamptz
  updatedAt         DateTime               @updatedAt @db.Timestamptz

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([featuredItemId])
  @@map("promotion")
}

enum MessageAuthor {
  BOT
  USER
  AGENT
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id                 String        @id @default(uuid())
  conversationId     String
  conversation       Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  evolutionMessageId String?       @unique
  author             MessageAuthor
  content            String
  status             MessageStatus @default(SENT)
  createdAt          DateTime      @default(now()) @db.Timestamptz

  @@index([conversationId])
  @@map("message")
}

enum NotificationType {
  NEW_ORDER
  PAYMENT_RECEIVED
  BOT_OFFLINE
  IDLE_CONVERSATION
  GENERIC
}

model Notification {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           NotificationType
  title          String
  body           String?
  /// Optional deep-link inside the dashboard (e.g. "/orders/<id>").
  link           String?
  /// When the notification was marked as read. Read notifications are deleted
  /// 24h after this timestamp by a lazy cleanup that runs on every list query.
  readAt         DateTime?        @db.Timestamptz
  createdAt      DateTime         @default(now()) @db.Timestamptz

  @@index([organizationId, createdAt])
  @@index([organizationId, readAt])
  @@map("notification")
}

model Report {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceType    ServiceType
  reportDate     DateTime     @db.Date
  totalOrders    Int          @default(0)
  canceledCount  Int          @default(0)
  cashCount      Int          @default(0)
  revenue        Decimal      @default(0) @db.Decimal(10, 2)
  paidRevenue    Decimal      @default(0) @db.Decimal(10, 2)
  orders         Json         @default("[]")
  generatedAt    DateTime     @default(now()) @db.Timestamptz
  createdAt      DateTime     @default(now()) @db.Timestamptz
  updatedAt      DateTime     @updatedAt @db.Timestamptz

  @@unique([organizationId, serviceType, reportDate])
  @@index([organizationId])
  @@index([organizationId, reportDate])
  @@map("report")
}
